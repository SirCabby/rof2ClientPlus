<?xml version="1.0" encoding="us-ascii"?>
<XML ID="EQInterfaceDefinitionLanguage">
<Composite>
	<Include>EQUI_Tab_Cam.xml</Include>
</Composite>
<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />
  <Screen item="RcpOptions">
    <ScreenID>RcpOptions</ScreenID>
    <RelativePosition>false</RelativePosition>
    <Location>
      <X>10</X>
      <Y>10</Y>
    </Location>
    <Size>
      <CX>260</CX>
      <CY>250</CY>
    </Size>
    <Text>rof2ClientPlus Options</Text>
    <Style_VScroll>false</Style_VScroll>
    <Style_HScroll>false</Style_HScroll>
    <Style_Transparent>false</Style_Transparent>
    <TooltipReference />
    <DrawTemplate>WDT_Def</DrawTemplate>
    <Style_Titlebar>true</Style_Titlebar>
    <Style_Closebox>true</Style_Closebox>
    <Style_Minimizebox>true</Style_Minimizebox>
    <Style_Border>true</Style_Border>
    <Style_Sizable>false</Style_Sizable>
    <!-- Controls are direct children of the Screen (not a TabBox/Page): a
         dynamically-created tab page renders but does not route mouse input to
         its child controls, so the sliders/checkbox were dead. Definitions live
         in EQUI_Tab_Cam.xml. -->
    <Pieces>Rcp_Enabled</Pieces>
    <Pieces>Rcp_LockMouse</Pieces>
    <Pieces>Rcp_SensXLabel</Pieces>
    <Pieces>Rcp_SensX</Pieces>
    <Pieces>Rcp_SensXValue</Pieces>
    <Pieces>Rcp_SensYLabel</Pieces>
    <Pieces>Rcp_SensY</Pieces>
    <Pieces>Rcp_SensYValue</Pieces>
    <Pieces>Rcp_SmoothLabel</Pieces>
    <Pieces>Rcp_Smooth</Pieces>
    <Pieces>Rcp_SmoothValue</Pieces>
  </Screen>
</XML>
